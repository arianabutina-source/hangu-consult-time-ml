# Comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO

# Optional overrides; default to ml/artifacts/*.joblib in this repo.
# CLASSIFIER_PIPELINE_PATH=/absolute/path/to/classifier_pipeline.joblib
# REGRESSOR_PIPELINE_PATH=/absolute/path/to/regressor_pipeline.joblib
# METADATA_PATH=/absolute/path/to/metadata.json
# CLASSIFICATION_MODELS_DIR=/absolute/path/to/models/classification
# REGRESSION_MODELS_DIR=/absolute/path/to/models/regression
